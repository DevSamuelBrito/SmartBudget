# Backend
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=SmartBudget;Username=postgres;Password=postgres
Redis__ConnectionString=your-upstash-redis-connection-string
Jwt__Key=your-secret-key-at-least-32-characters
Email__ApiKey=your-brevo-api-key
Email__FromEmail=your-email
FrontendUrl=http://localhost:3000

# Frontend

#client
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1/

#server
API_URL=http://backend:8080/api/v1/
# WARNING: Only set this if ALL subdomains of the specified domain are trusted.
# A broad domain (e.g. .yourdomain.com) makes the auth cookie valid for every subdomain.
COOKIE_DOMAIN=